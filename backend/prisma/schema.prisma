// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  vendors Vendor[]

  statTemplates           CategoryStatTemplate[]
  amenityTemplates        CategoryAmenityTemplate[]
  packageTemplates        CategoryPackageTemplate[]
  packageFeatureTemplates CategoryPackageFeatureTemplate[]
  sectionTemplates        CategorySectionTemplate[]

  createdAt DateTime @default(now())
}

model City {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  state String

  vendors Vendor[]

  createdAt DateTime @default(now())
}

model Vendor {
  id Int @id @default(autoincrement())

  name String
  slug String @unique

  description String?

  phone    String?
  whatsapp String?

  imageUrl String?

  rating Float @default(0)

  isElite Boolean @default(false)

  startingPrice Int?

  pricingUnit String?

  address   String?
  zipcode   String?
  latitude  Float?
  longitude Float?

  websiteUrl String?

  instagramUrl String?

  facebookUrl String?

  youtubeUrl String?

  linkedinUrl String?

  googleBusinessUrl String?

  categoryId Int
  cityId     Int

  category Category @relation(fields: [categoryId], references: [id])
  city     City     @relation(fields: [cityId], references: [id])

  images VendorImage[]

  stats        VendorStat[]
  amenities    VendorAmenity[]
  packages     VendorPackage[]
  reviews      VendorReview[]
  events       VendorEvent[]
  savedByUsers UserSavedVendor[]
  fieldValues  VendorFieldValue[]

  socialLinks VendorSocialLink[]

  ownerId Int?

  owner User? @relation(fields: [ownerId], references: [id])

  showPackages Boolean      @default(false)
  status       VendorStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@index([categoryId])
  @@index([cityId])
  @@index([zipcode])
}

model CategoryStatTemplate {
  id Int @id @default(autoincrement())

  categoryId Int

  label String

  icon String?

  sortOrder Int @default(0)

  category Category @relation(fields: [categoryId], references: [id])

  vendorStats VendorStat[]

  @@index([categoryId])
}

model VendorStat {
  id Int @id @default(autoincrement())

  vendorId Int

  templateId Int

  value String

  vendor Vendor @relation(fields: [vendorId], references: [id])

  template CategoryStatTemplate @relation(fields: [templateId], references: [id])

  @@index([vendorId])
}

model AmenityTemplate {
  id Int @id @default(autoincrement())

  name String

  slug String @unique

  categories CategoryAmenityTemplate[]

  vendors VendorAmenity[]
}

model CategoryAmenityTemplate {
  categoryId Int

  amenityId Int

  category Category @relation(fields: [categoryId], references: [id])

  amenity AmenityTemplate @relation(fields: [amenityId], references: [id])

  @@id([categoryId, amenityId])
}

model VendorAmenity {
  vendorId Int

  amenityId Int

  vendor Vendor @relation(fields: [vendorId], references: [id])

  amenity AmenityTemplate @relation(fields: [amenityId], references: [id])

  @@id([vendorId, amenityId])
  @@index([vendorId])
}

model CategoryPackageTemplate {
  id Int @id @default(autoincrement())

  categoryId Int

  name String

  sortOrder Int @default(0)

  category Category @relation(fields: [categoryId], references: [id])

  vendorPackages VendorPackage[]

  @@index([categoryId])
}

model PackageFeatureTemplate {
  id Int @id @default(autoincrement())

  name String

  slug String @unique

  packageFeatures VendorPackageFeature[]
  categories      CategoryPackageFeatureTemplate[]
}

model VendorPackage {
  id Int @id @default(autoincrement())

  vendorId Int

  packageTemplateId Int

  price String

  vendor Vendor @relation(fields: [vendorId], references: [id])

  packageTemplate CategoryPackageTemplate @relation(fields: [packageTemplateId], references: [id])

  features VendorPackageFeature[]

  @@index([vendorId])
  @@index([packageTemplateId])
}

model VendorPackageFeature {
  packageId Int

  featureId Int

  package VendorPackage @relation(fields: [packageId], references: [id])

  feature PackageFeatureTemplate @relation(fields: [featureId], references: [id])

  @@id([packageId, featureId])
}

model CategoryPackageFeatureTemplate {
  categoryId Int

  featureId Int

  category Category @relation(fields: [categoryId], references: [id])

  feature PackageFeatureTemplate @relation(fields: [featureId], references: [id])

  @@id([categoryId, featureId])
}

model VendorReview {
  id Int @id @default(autoincrement())

  vendorId Int

  reviewerName String

  rating Int

  comment String

  isApproved Boolean @default(true)

  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model VendorEvent {
  id Int @id @default(autoincrement())

  vendorId Int

  eventType String

  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([eventType])
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

model User {
  id Int @id @default(autoincrement())

  name String?

  email String? @unique

  phone String? @unique

  password String?

  googleId String? @unique

  role UserRole @default(CUSTOMER)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  savedVendors UserSavedVendor[]

  ownedVendors Vendor[]
}

model OtpVerification {
  id Int @id @default(autoincrement())

  phone String

  otp String

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([phone])
}

model UserSavedVendor {
  id Int @id @default(autoincrement())

  userId Int

  vendorId Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([userId, vendorId])
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

model CategorySectionTemplate {
  id         Int      @id @default(autoincrement())
  categoryId Int
  key        String
  label      String
  sortOrder  Int      @default(0)
  isEnabled  Boolean  @default(true)
  category   Category @relation(fields: [categoryId], references: [id])

  fields CategoryFieldTemplate[]

  @@unique([categoryId, key])
  @@index([categoryId])
}

model CategoryFieldTemplate {
  id             Int     @id @default(autoincrement())
  sectionId      Int
  key            String
  label          String
  fieldType      String
  required       Boolean @default(false)
  sortOrder      Int     @default(0)
  placeholder    String?
  helpText       String?
  validationJson Json?
  defaultValue   Json?

  section CategorySectionTemplate @relation(fields: [sectionId], references: [id])
  options CategoryFieldOption[]
  values  VendorFieldValue[]

  @@unique([sectionId, key])
  @@index([sectionId])
}

model CategoryFieldOption {
  id        Int    @id @default(autoincrement())
  fieldId   Int
  label     String
  value     String
  sortOrder Int    @default(0)

  field CategoryFieldTemplate @relation(fields: [fieldId], references: [id])

  @@index([fieldId])
}

model VendorFieldValue {
  id        Int   @id @default(autoincrement())
  vendorId  Int
  fieldId   Int
  valueJson Json?

  vendor Vendor                @relation(fields: [vendorId], references: [id])
  field  CategoryFieldTemplate @relation(fields: [fieldId], references: [id])

  @@unique([vendorId, fieldId])
  @@index([vendorId])
}

model VendorImage {
  id        Int     @id @default(autoincrement())
  vendorId  Int
  imageUrl  String
  altText   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  mediaType String? // image, video, logo
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}

model VendorSocialLink {
  id        Int     @id @default(autoincrement())
  vendorId  Int
  type      String
  url       String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
}
